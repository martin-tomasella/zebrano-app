{
  "expo": {
    "name": "Zebrano",
    "slug": "zebrano-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0f0e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.martintomasella.zebrano"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#0d0f0e"
      },
      "package": "com.martintomasella.zebrano",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        { "photosPermission": "Zebrano necesita acceso a tus fotos para adjuntar planos." }
      ],
      [
        "expo-camera",
        { "cameraPermission": "Zebrano necesita la cámara para fotografiar planos y espacios." }
      ],
      [
        "expo-av",
        { "microphonePermission": "Zebrano necesita el micrófono para notas de voz." }
      ]
    ],
    "scheme": "zebrano",
    "extra": {
      "eas": { "projectId": "699fc2d9-0640-409b-a3f3-9a13a7f29dfb" },
      "supabaseUrl": "https://xsciujuvkbubnhhnpcix.supabase.co",
      "supabaseAnonKey": "sb_publishable_gI_zCp__hlMim3bIhXX7jg_QwY5MwzZ",
      "n8nWebhookBase": "https://n8n-n8n.z8ixjp.easypanel.host/webhook"
    }
  }
}
